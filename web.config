<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- Chuyển tiếp các request /docserver/ sang Node.js Document Server (127.0.0.1:8081) -->
        <rule name="DocServer Proxy" stopProcessing="true">
          <match url="^docserver/(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:5500/{R:1}" />
        </rule>
        
        <!-- Chuyển tiếp toàn bộ request dưới prefix /onlyoffice/ sang ONLYOFFICE (127.0.0.1:8000), tự động loại bỏ prefix và version ảo (như 9.4.0-...) -->
        <rule name="OnlyOffice Gateway Proxy" stopProcessing="true">
          <match url="^onlyoffice/(?:[\d\.]+-[\da-fA-F]+/)?(.*)$" />
          <action type="Rewrite" url="http://127.0.0.1:5500/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
          </serverVariables>
        </rule>

        <!-- Chuyển tiếp các request assets/cache của OnlyOffice (bao gồm thư mục phiên bản dạng /9.4.0-.../ hoặc truy cập trực tiếp từ root) -->
        <rule name="OnlyOffice Assets Proxy" stopProcessing="true">
          <match url="^(?:[\w\.-]+/)?(web-apps|sdkjs|fonts|welcome|dictionaries|info|coauthoring|cache)(/.*)?$" />
          <action type="Rewrite" url="http://127.0.0.1:5500//{R:1}{R:2}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
          </serverVariables>
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
