# Runtime document data and local signing material
backend-app/storage/.draft-signing-secret
backend-app/storage/contract-drafts/**
backend-app/storage/drafts/**
backend-app/storage/template-workspaces/**
backend-app/samples/backups/**
backend-app/uploads/**
!backend-app/uploads/.gitkeep

# Production secrets are created only on the deployment host.
.env.production
