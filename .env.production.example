# Sao chép file này thành .env.production trên server. Không commit secret thật.
NODE_ENV=production
PORT=8081

# SQL API Gateway hiện tại của hệ thống HR.
SQL_API_BASE=http://nhansu2.bms79.com
SQL_API_USER=

# Thay SERVER_IP_OR_DOMAIN bằng IP/domain mà trình duyệt người dùng truy cập.
# Nếu có HTTPS, dùng https://hr.example.com và bỏ :8080 khi reverse proxy ở 443.
DOCUMENT_PUBLIC_BASE_URL=http://SERVER_IP_OR_DOMAIN:8080/docserver
DOCUMENT_INTERNAL_BASE_URL=http://backend-app:8081
ONLYOFFICE_PUBLIC_URL=http://SERVER_IP_OR_DOMAIN:8080/onlyoffice

ONLYOFFICE_JWT_ENABLED=true
ONLYOFFICE_JWT_SECRET=THAY_BANG_SECRET_NGAU_NHIEN_TOI_THIEU_32_KY_TU
DRAFT_SIGNING_SECRET=THAY_BANG_SECRET_KHAC_NGAU_NHIEN_TOI_THIEU_32_KY_TU

DRAFT_TTL_HOURS=24
MAX_DOCX_SIZE_MB=20
CORS_ALLOWED_ORIGINS=http://SERVER_IP_OR_DOMAIN:8080
