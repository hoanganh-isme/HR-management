# Cấu hình phát triển cục bộ, không đặt secret thật vào file này.
NODE_ENV=development
PORT=8081

# SQL Gateway thật hoặc Gateway local nếu môi trường của bạn có cung cấp.
SQL_API_BASE=http://nhansu2.bms79.com
SQL_API_USER=admin
SQL_API_TIMEOUT_MS=30000
SQL_API_RETRY_COUNT=2
SQL_API_RETRY_BASE_DELAY_MS=300
SQL_API_KEEP_ALIVE=true
SQL_GATEWAY_MAX_GET_URL_LENGTH=7000

# URL trình duyệt và URL OnlyOffice dùng để tải file/callback.
DOCUMENT_PUBLIC_BASE_URL=http://127.0.0.1:8081
DOCUMENT_INTERNAL_BASE_URL=http://host.docker.internal:8081
ONLYOFFICE_PUBLIC_URL=http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:4173,http://localhost:4173

ONLYOFFICE_JWT_ENABLED=false
ONLYOFFICE_JWT_SECRET=
DRAFT_SIGNING_SECRET=

# HR_Documents đang là luồng tương thích cũ, mặc định phải tắt.
USE_LEGACY_HR_DOCUMENTS=false

