NODE_ENV=production
PORT=8081

SQL_API_BASE=https://hr-api.example.com
SQL_API_USER=service-document-api
SQL_API_TIMEOUT_MS=30000
SQL_API_RETRY_COUNT=2
SQL_API_RETRY_BASE_DELAY_MS=500
SQL_API_KEEP_ALIVE=true
SQL_GATEWAY_MAX_GET_URL_LENGTH=7000

DOCUMENT_PUBLIC_BASE_URL=https://hr.example.com/docserver
DOCUMENT_INTERNAL_BASE_URL=http://document-api:8081
ONLYOFFICE_PUBLIC_URL=https://hr.example.com/onlyoffice
CORS_ALLOWED_ORIGINS=https://hr.example.com

ONLYOFFICE_JWT_ENABLED=true
ONLYOFFICE_JWT_SECRET=
DRAFT_SIGNING_SECRET=
USE_LEGACY_HR_DOCUMENTS=false
